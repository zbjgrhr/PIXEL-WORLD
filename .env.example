# Keep real keys in .env.local. Never commit them.
DASHSCOPE_API_KEY=your-api-key-here
OPENAI_API_KEY=your-api-key-here
OPENROUTER_API_KEY=your-api-key-here
TOGETHER_API_KEY=your-api-key-here
TENCENT_TOKENHUB_API_KEY=your-api-key-here
POLLINATIONS_API_KEY=your-api-key-here
HF_TOKEN=hf_your-token-here
# Cloudflare uses one combined value so the existing single credential field remains simple.
CLOUDFLARE_WORKERS_AI_CREDENTIALS=account-id|api-token
# Optional: use https://tokenhub-intl.tencentmaas.com for the international TokenHub region.
TENCENT_TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com
